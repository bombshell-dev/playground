{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2023", "DOM"],
        "types": ["node"],
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "allowImportingTsExtensions": true,
        "rewriteRelativeImportExtensions": true,
        "rootDir": "src",
        "outDir": "dist/types"
    },
    "include": ["src/**/*.ts"]
}
